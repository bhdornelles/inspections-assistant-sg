<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="12dp"
    app:strokeColor="@color/navy_primary_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/textSheetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/overlay_sheet_title"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/navy_primary" />

        <TextView
            android:id="@+id/textSheetSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/overlay_step1_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?android:attr/textColorSecondary" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            app:dividerThickness="1dp" />

        <!-- Passo 1: família -->
        <LinearLayout
            android:id="@+id/panelStepFamily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFamilyFi"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="52dp"
                android:text="@string/overlay_family_fi" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFamilyDf"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="52dp"
                android:text="@string/overlay_family_df" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFamilyE26"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="52dp"
                android:text="@string/overlay_family_e26rnn" />
        </LinearLayout>

        <!-- Passo 2: situação FI (ocupada / vaga) -->
        <LinearLayout
            android:id="@+id/panelStepFiSituation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFiOccupied"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="52dp"
                android:text="@string/profile_fi_occupied" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFiVacant"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="52dp"
                android:text="@string/profile_fi_vacant" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackFi"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/overlay_back" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSheet"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/close_panel" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
