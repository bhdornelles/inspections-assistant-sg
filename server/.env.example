# Copie este ficheiro para .env (comando abaixo) e preencha os valores NO .env.
# Nao coloque senhas reais aqui se o projeto for para o Git — so no .env (que o Git ignora).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Opcional: modelo multimodal para POST /inspect-vision (se vazio, usa ANTHROPIC_MODEL)
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-20250514
# INSPECT_LOG_MODEL=true — no terminal do uvicorn, loga resposta + question_focus da IA

# Login no app: obrigatorio preencher no .env (pode inventar frases longas e diferentes uma da outra)
# Exemplo de geracao no Mac: openssl rand -base64 48
JWT_SECRET=

# Chave para aprovar inspetores (outra senha, NAO igual a JWT_SECRET)
ADMIN_API_KEY=

# AUTH_DB_PATH=./auth.db

# PROXY_BEARER_TOKEN=

PORT=8787
